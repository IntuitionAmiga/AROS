include $(SRCDIR)/config/aros.cfg

FILES := copymem copymemquick

USER_INCLUDES := -I$(SRCDIR)/arch/m68k-ie/include

# proto/iewarp.h is generated by kernel-iewarp and needed by iewarp_consumer.h
#MM- kernel-exec-ie-m68k : kernel-iewarp-includes

%build_archspecific \
  mainmmake=kernel-exec maindir=rom/exec \
  arch=ie-m68k files="$(FILES)"

%common
